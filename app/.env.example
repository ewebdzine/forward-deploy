# Forward Deploy - the complete configuration contract.
# Every setting is an env var; copy to .env (never committed) and fill in.
# /forward-deploy:kickoff collects these interactively.

# --- Anthropic (powers the SOP + plan chats) ---
ANTHROPIC_API_KEY=
# Optional: override the default model.
ANTHROPIC_MODEL=claude-sonnet-5

# --- Postgres (plans, users, departments; any Postgres works - Neon/Vercel Postgres on Vercel) ---
DATABASE_URL=postgres://user:password@host:5432/forward_deploy

# --- Auth.js (magic-link login) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# The app's public URL (Vercel sets VERCEL_URL automatically; set this for self-host).
AUTH_URL=http://localhost:3000

# --- SMTP (magic-link delivery; Resend/Brevo free tiers work) ---
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Forward Deploy <no-reply@example.com>"

# --- Source control: github (default) or bitbucket ---
SOURCE_PROVIDER=github
# github: REPO_OWNER = org/user. Token needs repo read + contents write (SOP commits).
# bitbucket: REPO_OWNER = workspace, REPO_NAME = repo slug; auth = Atlassian account
#   email + API token (id.atlassian.com > Security > API tokens) with repository
#   read + write scopes. Leave GITHUB_TOKEN empty when using bitbucket, and vice versa.
GITHUB_TOKEN=
BITBUCKET_EMAIL=
BITBUCKET_API_TOKEN=
REPO_OWNER=
REPO_NAME=
REPO_BRANCH=main

# --- Repo paths ---
SOP_PATH=docs/sops
COMPANY_DOCS_PATH=docs/company
# One canon per vendor product the company uses (written by /forward-deploy:capture-software)
SOFTWARE_DOCS_PATH=docs/software

# --- Slack capture bot (optional; absent = feature off, zero residue) ---
# Create a Slack app (from a manifest or by hand): enable Event Subscriptions
# pointing at <your-app-url>/api/slack/events, subscribe to message.im, add
# bot scopes im:history, chat:write, users:read, users:read.email, then
# install to the workspace. DMing the bot is the opt-in; senders must match
# an invited Forward Deploy email.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- Skills API (bearer token /forward-deploy:review-plans and :pull-plan authenticate with) ---
# Generate with: openssl rand -base64 32
FORWARD_DEPLOY_TOKEN=

# --- Seeding (used by `npm run seed` to create the first admin) ---
ADMIN_EMAIL=
ADMIN_NAME=
