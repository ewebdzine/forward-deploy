# Forward Deploy - the complete configuration contract.
# Every setting is an env var; copy to .env (never committed) and fill in.
# /forward-deploy:kickoff collects these interactively.

# --- Anthropic (powers the SOP + plan chats) ---
ANTHROPIC_API_KEY=
# Optional: override the default model.
ANTHROPIC_MODEL=claude-sonnet-5

# --- Postgres (plans, users, departments; any Postgres works - Neon/Vercel Postgres on Vercel) ---
DATABASE_URL=postgres://user:password@host:5432/forward_deploy

# --- Auth.js (magic-link login) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# The app's public URL (Vercel sets VERCEL_URL automatically; set this for self-host).
AUTH_URL=http://localhost:3000

# --- SMTP (magic-link delivery; Resend/Brevo free tiers work) ---
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Forward Deploy <no-reply@example.com>"

# --- Source control (v1: GitHub; token needs repo read + contents write for SOP commits) ---
GITHUB_TOKEN=
REPO_OWNER=
REPO_NAME=
REPO_BRANCH=main

# --- Repo paths ---
SOP_PATH=docs/sops
COMPANY_DOCS_PATH=docs/company

# --- Skills API (bearer token /forward-deploy:review-plans and :pull-plan authenticate with) ---
# Generate with: openssl rand -base64 32
FORWARD_DEPLOY_TOKEN=

# --- Seeding (used by `npm run seed` to create the first admin) ---
ADMIN_EMAIL=
ADMIN_NAME=
